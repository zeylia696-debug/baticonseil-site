rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Données du site — lecture publique, écriture admin seulement
    match /site/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Messages de contact — création publique, lecture/suppression admin seulement
    match /messages/{msgId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
